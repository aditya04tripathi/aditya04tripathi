{
	"$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
	"vcs": { "enabled": false },
	"files": {
		"ignoreUnknown": true,
		"includes": ["src/**", "*.astro", "*.mjs", "*.ts", "*.svelte", "svelte.config.js"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
